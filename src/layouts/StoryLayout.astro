---
import Layout from './Layout.astro';

interface Props {
  title: string;
  subtitle?: string;
  date?: string;
  author?: string;
}

const { title, subtitle, date, author } = Astro.props;
---

<Layout>
  <div class="story-container">
    <header class="story-header">
      <h1 class="story-title">{title}</h1>
      {subtitle && <p class="story-subtitle">{subtitle}</p>}
      <div class="story-meta">
        {date && <span class="meta-date">{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
        {author && <span class="meta-author">By {author}</span>}
      </div>
    </header>

    <article class="story-content">
      <slot />
    </article>
  </div>
</Layout>

<style>
  .story-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .story-header {
    margin-bottom: 60px;
    padding-top: 40px;
  }

  .story-title {
    font-size: 48px;
    line-height: 1.2;
    margin: 0 0 20px 0;
    color: #111827;
    font-weight: 700;
  }

  .story-subtitle {
    font-size: 20px;
    line-height: 1.5;
    color: #4b5563;
    margin: 0 0 30px 0;
  }

  .story-meta {
    display: flex;
    gap: 24px;
    font-size: 14px;
    color: #6b7280;
  }

  .meta-date,
  .meta-author {
    display: flex;
    align-items: center;
  }

  .story-content {
    font-size: 18px;
    line-height: 1.8;
    color: #1f2937;
  }

  /* Narrative component spacing */
  .story-content :global(> * + *) {
    margin-top: 40px;
  }

  @media (max-width: 768px) {
    .story-container {
      padding: 0 16px;
    }

    .story-title {
      font-size: 32px;
    }

    .story-subtitle {
      font-size: 18px;
    }

    .story-meta {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
