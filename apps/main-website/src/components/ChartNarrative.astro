---
export interface Props {
  title?: string;
  description?: string;
  children?: any;
}

const { title, description, children } = Astro.props;
---

<figure class="chart-narrative">
  {title && <h3>{title}</h3>}
  {description && <p class="description">{description}</p>}
  <div class="chart-content">
    <slot />
  </div>
</figure>

<style>
  .chart-narrative {
    margin: 3rem 0;
    padding: 2rem;
    background: #fafbfc;
    border-radius: 8px;
  }

  h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.3rem;
  }

  .description {
    color: #666;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .chart-content {
    background: white;
    padding: 1.5rem;
    border-radius: 4px;
  }
</style>
